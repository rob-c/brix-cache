#!/usr/bin/env bash
#
# pre-push — run the FAST test tier before a push so obviously-broken code never
# leaves your machine.  ~4min (vs ~20min full).  The full suite
# (PYTHONPATH=tests python3 -m cmdscripts.operator_runtime suite) remains the
# pre-merge gate.
#
# Install (once):   git config core.hooksPath tools/git-hooks
#          or:      tools/git-hooks/install.sh
#
# Bypass:  git push --no-verify          (one-off)
#          SKIP_FAST_TESTS=1 git push    (one-off, env)
#
set -u

if [ "${SKIP_FAST_TESTS:-0}" = "1" ]; then
    echo "[pre-push] SKIP_FAST_TESTS=1 → skipping fast tests"
    exit 0
fi

REPO="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0

if [ ! -f "$REPO/tests/cmdscripts/operator_runtime.py" ]; then
    echo "[pre-push] suite runner not found — skipping (nothing to gate)."
    exit 0
fi

# Static invariant guards first — they take seconds and catch what the test
# tier can't (seam bypasses, size ratchets, doc drift). See tools/ci/README.md.
echo "[pre-push] running tools/ci guards"
for g in "$REPO"/tools/ci/check_*.sh; do
    if ! "$g"; then
        echo "[pre-push] ✗ guard failed: ${g##*/} — push blocked (bypass: --no-verify)"
        exit 1
    fi
done

echo "[pre-push] running fast test tier — ~4min; bypass with 'git push --no-verify'"
echo "[pre-push] (tests run against the CURRENT build — rebuild first if you changed src/)"

(cd "$REPO" && PYTHONPATH=tests python3 -m cmdscripts.operator_runtime suite --fast)
rc=$?

if [ "$rc" -ne 0 ]; then
    echo ""
    echo "[pre-push] ✗ fast tests FAILED — push blocked."
    echo "[pre-push]   reproduce: PYTHONPATH=tests python3 -m cmdscripts.operator_runtime suite --fast"
    echo "[pre-push]   bypass:    git push --no-verify   (or SKIP_FAST_TESTS=1 git push)"
fi
exit "$rc"

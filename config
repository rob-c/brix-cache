# ---------------------------------------------------------------------------
# phase-47 W1: for the DYNAMIC build, emit ONE combined .so containing every
# non-filter module accumulated above.  ngx_module_type is cosmetic here — each
# module's real type (STREAM/HTTP) comes from its own ngx_module_t struct at
# load, so the stream + http modules coexist in a single .so and register into
# the correct module slot.  Deduplicate srcs (metrics/tracking.c is listed by
# both the stream and metrics blocks) so nothing compiles/links twice.  The .so
# is named after the first module (ngx_stream_xrootd_module.so) and must be the
# first load_module line so its symbols back the HTTP modules via RTLD_GLOBAL.
if [ "$ngx_module_link" = DYNAMIC ]; then
    xrd_comb_srcs=""
    for _xrd_s in $xrd_dyn_srcs; do
        case " $xrd_comb_srcs " in
            *" $_xrd_s "*) ;;
            *) xrd_comb_srcs="$xrd_comb_srcs $_xrd_s" ;;
        esac
    done
    ngx_module_type=HTTP
    ngx_module_name="ngx_stream_xrootd_module \
                     ngx_http_xrootd_metrics_module \
                     ngx_http_xrootd_srr_module \
                     ngx_http_xrootd_webdav_module \
                     ngx_http_xrootd_s3_module \
                     ngx_http_xrootd_dashboard_module \
                     ngx_stream_xrootd_cms_srv_module"
    ngx_module_incs="$ngx_addon_dir/src"
    ngx_module_srcs="$xrd_comb_srcs"
    ngx_module_deps="$xrd_dyn_deps"
    ngx_module_libs="$xrd_dyn_libs"
    . auto/module
fi

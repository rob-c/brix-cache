# nginx module config — XRootD stream module + Prometheus metrics HTTP module
# Requires: --with-stream
# Uses OpenSSL (via -lssl -lcrypto) for GSI x509 authentication
# VOMS support: loaded at runtime via dlopen(libvomsapi.so.1) — no compile-time
# link needed.  Install voms-libs on EL9 to enable VO ACL enforcement.

# Compiler hardening flags:
#   -D_FORTIFY_SOURCE=2          runtime buffer-overflow detection via glibc wrappers
#   -fstack-protector-strong     stack canary for functions with local buffers
#   -fstack-clash-protection     probe stack on entry to catch stack-clash attacks (GCC 8+)
#   -fcf-protection=full         Intel CET control-flow integrity (x86, GCC 8+)
#   -Wformat -Werror=format-security  reject printf calls with non-literal format strings
#   -Wvla                        reject variable-length arrays — wire-controlled stack
#                                growth is forbidden, so make the invariant compiler-enforced
#   -Wstrict-prototypes -Wold-style-definition  reject K&R/() prototypes (require (void))
# These are additive and safe to combine with nginx's own CFLAGS — the flags here
# apply globally (module + nginx core), so only warnings nginx's own source is
# already clean of may be promoted to -Werror. -Wvla / -Wstrict-prototypes /
# -Wold-style-definition meet that bar; noisier flags (-Wshadow, -Wcast-qual,
# -Wconversion) do not and must stay opt-in (e.g. --with-cc-opt) for module-only audits.
# Alternatively, pass via:  ./configure ... --with-cc-opt="-D_FORTIFY_SOURCE=2 ..."
# For full RELRO/BIND_NOW, defaulted below (NGX_LD_OPT); override with --with-ld-opt.
CFLAGS="$CFLAGS -D_GNU_SOURCE -D_FORTIFY_SOURCE=2 -fstack-protector-strong -fstack-clash-protection -fcf-protection=full -Wformat -Werror=format-security -Wvla -Wstrict-prototypes -Wold-style-definition"

# Link hardening for the dynamic module (.so). Appended unless the operator
# already passed equivalent flags via --with-ld-opt. Full RELRO + BIND_NOW make
# the GOT read-only after startup; noexecstack marks the stack non-executable.
case "$NGX_LD_OPT" in
    *relro*) : ;;  # operator already set it; don't double-add
    *) NGX_LD_OPT="$NGX_LD_OPT -Wl,-z,relro -Wl,-z,now -Wl,-z,noexecstack" ;;
esac

# Performance profile (Phase 33 D1: v2 is now the DEFAULT, not opt-in).
# The Phase-33 audit found the hardening flags above cost nothing measurable on
# the read hot path, so release builds default to the RHEL-9 baseline ISA.
# Override by exporting XROOTD_OPTIMIZE before ./configure, e.g.
#     XROOTD_OPTIMIZE=v3 ./configure ... --add-module=...
#   v2      -O3 -march=x86-64-v2   DEFAULT.  Safe RHEL 9 baseline (SSE4.2/POPCNT
#                                  on every x86-64-v2 CPU) — lets the compiler emit
#                                  SSE4.2 everywhere, not just in the target-
#                                  attributed CRC functions.  Redistributable on
#                                  any x86-64-v2 host; the build host needs no
#                                  special ISA.
#   v3      -O3 -march=x86-64-v3   AVX2/BMI2 — only when every CPU in the fleet
#                                  supports it (Haswell+ / Zen+).
#   native  -O3 -march=native      tuned to THIS build host; do not redistribute
#                                  the resulting binary to other hardware.
#   none    (off|no|0)             escape hatch: add no optimisation flags, leave
#                                  nginx's own -O untouched (portable/debug builds).
# Compile-time only; composes with the hardening flags above.  For cross-module
# link-time optimisation, additionally pass at the top level:
#     --with-cc-opt="-flto=auto" --with-ld-opt="-flto=auto"
# -O3 here appears after nginx's own -O, so the last -O wins (no conflict).
case "${XROOTD_OPTIMIZE:-v2}" in
    v2|yes|YES|1) CFLAGS="$CFLAGS -O3 -march=x86-64-v2 -fno-plt"
                  echo " + xrootd: performance profile = v2 (-O3 -march=x86-64-v2) [default]" ;;
    v3)           CFLAGS="$CFLAGS -O3 -march=x86-64-v3 -fno-plt"
                  echo " + xrootd: performance profile = v3 (-O3 -march=x86-64-v3)" ;;
    native)       CFLAGS="$CFLAGS -O3 -march=native -fno-plt"
                  echo " + xrootd: performance profile = native (-O3 -march=native)" ;;
    none|off|no|NO|0) echo " + xrootd: performance profile = none (nginx -O untouched)" ;;
    *)            echo "WARNING: unknown XROOTD_OPTIMIZE='$XROOTD_OPTIMIZE'" \
                       "(use v2|v3|native|none); defaulting to v2" >&2
                  CFLAGS="$CFLAGS -O3 -march=x86-64-v2 -fno-plt" ;;
esac

# --with-threads is required: async I/O, TPC, and S3 PUT all depend on it
if [ "$USE_THREADS" != YES ]; then
    echo "ERROR: --with-threads is required. Re-run configure with --with-threads." >&2
    exit 1
fi

# libxml2 is required for WebDAV PROPFIND XML parsing.
#
# The external-library flags below are captured into XROOTD_*_LIBS and added to
# each module's ngx_module_libs (see the ". auto/module" blocks), NOT only to
# CORE_LIBS.  CORE_LIBS links the nginx *binary*; for a DYNAMIC module build
# (--with-stream=dynamic, as the RPM uses) the per-module .so is linked with
# ngx_module_libs, so libs that live only in CORE_LIBS would be missing from the
# .so and the module would fail to dlopen() with "undefined symbol: ..." on a
# stock nginx that does not itself link xml2/jansson/curl/krb5.
if command -v pkg-config >/dev/null 2>&1 && pkg-config --exists libxml-2.0; then
    CFLAGS="$CFLAGS $(pkg-config --cflags libxml-2.0) -DXROOTD_HAVE_LIBXML2=1"
    XROOTD_XML2_LIBS="$(pkg-config --libs libxml-2.0)"
    CORE_LIBS="$CORE_LIBS $XROOTD_XML2_LIBS"
else
    echo "ERROR: libxml2 is required for WebDAV PROPFIND XML parsing." \
         "Install libxml2-devel (RHEL/CentOS) or libxml2-dev (Debian/Ubuntu)." >&2
    exit 1
fi

echo " + xrootd WebDAV: native MKCOL/DELETE handlers enabled"

if command -v pkg-config >/dev/null 2>&1 && pkg-config --exists jansson; then
    CFLAGS="$CFLAGS $(pkg-config --cflags jansson) -DXROOTD_HAVE_JANSSON=1"
    XROOTD_JANSSON_LIBS="$(pkg-config --libs jansson)"
    CORE_LIBS="$CORE_LIBS $XROOTD_JANSSON_LIBS"
else
    echo "ERROR: jansson library is required but was not found." \
         "Install jansson-devel (RHEL/CentOS) or libjansson-dev (Debian/Ubuntu)." >&2
    exit 1
fi

# libcurl is required for WebDAV HTTP-TPC COPY operations
if command -v pkg-config >/dev/null 2>&1 && pkg-config --exists libcurl; then
    CFLAGS="$CFLAGS $(pkg-config --cflags libcurl)"
    XROOTD_CURL_LIBS="$(pkg-config --libs libcurl)"
    CORE_LIBS="$CORE_LIBS $XROOTD_CURL_LIBS"
else
    echo "ERROR: libcurl is required for WebDAV HTTP-TPC COPY operations." \
         "Install libcurl-devel (RHEL/CentOS) or libcurl4-openssl-dev (Debian/Ubuntu)." >&2
    exit 1
fi

# Kerberos 5 is optional at build time. If unavailable, xrootd_auth krb5
# remains a config-time error via src/auth/krb5/config.c.
#   Detection order: pkg-config (preferred) then krb5-config.  Some hosts ship
#   the MIT krb5 'krb5-config' tool + headers but no 'krb5.pc' pkg-config file
#   (a historical Debian split where headers came via krb5-multidev); the
#   krb5-config fallback keeps Kerberos enabled on those hosts instead of
#   silently disabling it.  Both emit the same flags: -lkrb5 -lk5crypto -lcom_err
#   (raw MIT libkrb5; the module never links GSS-API).
if command -v pkg-config >/dev/null 2>&1 && pkg-config --exists krb5; then
    CFLAGS="$CFLAGS $(pkg-config --cflags krb5) -DXROOTD_HAVE_KRB5=1"
    XROOTD_KRB5_LIBS="$(pkg-config --libs krb5)"
    CORE_LIBS="$CORE_LIBS $XROOTD_KRB5_LIBS"
    echo " + xrootd auth: Kerberos 5 plugin enabled (pkg-config)"
elif command -v krb5-config >/dev/null 2>&1; then
    CFLAGS="$CFLAGS $(krb5-config --cflags) -DXROOTD_HAVE_KRB5=1"
    XROOTD_KRB5_LIBS="$(krb5-config --libs)"
    CORE_LIBS="$CORE_LIBS $XROOTD_KRB5_LIBS"
    echo " + xrootd auth: Kerberos 5 plugin enabled (krb5-config)"
else
    echo " + xrootd auth: Kerberos 5 plugin disabled" \
         "(neither 'krb5.pc' nor 'krb5-config' found; install krb5-devel" \
         "[RHEL] or libkrb5-dev [Debian] to enable xrootd_auth krb5)"
fi

# Optional io_uring disk-I/O backend (phase-44). Double-gated: operator opt-in
# via XROOTD_ENABLE_IO_URING *and* liburing actually present. Default OFF — a
# bare ./configure never links -luring and the backend compiles to stubs (the
# selector falls back to the thread pool). XROOTD_URING_LIBS is appended to the
# stream module's ngx_module_libs below (NOT only CORE_LIBS) so the DYNAMIC .so
# resolves io_uring_* at dlopen.
XROOTD_URING_LIBS=""
if [ -n "$XROOTD_ENABLE_IO_URING" ] \
   && command -v pkg-config >/dev/null 2>&1 \
   && pkg-config --exists liburing; then
    CFLAGS="$CFLAGS $(pkg-config --cflags liburing) -DXROOTD_HAVE_LIBURING=1"
    XROOTD_URING_LIBS="$(pkg-config --libs liburing)"   # normally: -luring
    echo " + xrootd: io_uring disk-I/O backend enabled (liburing $(pkg-config --modversion liburing))"
fi

# Compression codecs (phase-42). The shared codec abstraction (src/core/compat/codec_*.c)
# is one ngx-free kernel used by the module here and by libxrdc (client). Each
# codec is compile-time-gated like krb5/fuse3: when its dev lib is present we add
# -DXROOTD_HAVE_<C> + its link flags; otherwise the backend compiles to an
# "unavailable" descriptor and the codec degrades gracefully. zlib (gzip/deflate)
# is effectively mandatory (nginx already links it); the rest are optional.
# XROOTD_CODEC_LIBS accumulates the per-.so link flags (added to ngx_module_libs
# below, NOT only CORE_LIBS — required for the DYNAMIC module build to resolve).
XROOTD_CODEC_LIBS=""
if command -v pkg-config >/dev/null 2>&1 && pkg-config --exists zlib; then
    CFLAGS="$CFLAGS $(pkg-config --cflags zlib) -DXROOTD_HAVE_ZLIB=1"
    XROOTD_CODEC_LIBS="$XROOTD_CODEC_LIBS $(pkg-config --libs zlib)"
else
    CFLAGS="$CFLAGS -DXROOTD_HAVE_ZLIB=1"
    XROOTD_CODEC_LIBS="$XROOTD_CODEC_LIBS -lz"
fi
if command -v pkg-config >/dev/null 2>&1 && pkg-config --exists libzstd; then
    CFLAGS="$CFLAGS $(pkg-config --cflags libzstd) -DXROOTD_HAVE_ZSTD=1"
    XROOTD_CODEC_LIBS="$XROOTD_CODEC_LIBS $(pkg-config --libs libzstd)"
    echo " + xrootd compression: zstd enabled"
else
    echo " + xrootd compression: zstd disabled (install libzstd-devel to enable)"
fi
if command -v pkg-config >/dev/null 2>&1 && pkg-config --exists liblzma; then
    CFLAGS="$CFLAGS $(pkg-config --cflags liblzma) -DXROOTD_HAVE_LZMA=1"
    XROOTD_CODEC_LIBS="$XROOTD_CODEC_LIBS $(pkg-config --libs liblzma)"
    echo " + xrootd compression: xz/lzma enabled"
else
    echo " + xrootd compression: xz/lzma disabled (install xz-devel to enable)"
fi
if command -v pkg-config >/dev/null 2>&1 && pkg-config --exists libbrotlienc libbrotlidec; then
    CFLAGS="$CFLAGS $(pkg-config --cflags libbrotlienc) -DXROOTD_HAVE_BROTLI=1"
    XROOTD_CODEC_LIBS="$XROOTD_CODEC_LIBS $(pkg-config --libs libbrotlienc libbrotlidec)"
    echo " + xrootd compression: brotli enabled"
else
    echo " + xrootd compression: brotli disabled (install libbrotli-devel to enable)"
fi
# bzip2 commonly ships no .pc file: probe the header/lib directly (krb5-config style).
if command -v pkg-config >/dev/null 2>&1 && pkg-config --exists bzip2; then
    CFLAGS="$CFLAGS $(pkg-config --cflags bzip2) -DXROOTD_HAVE_BZIP2=1"
    XROOTD_CODEC_LIBS="$XROOTD_CODEC_LIBS $(pkg-config --libs bzip2)"
    echo " + xrootd compression: bzip2 enabled (pkg-config)"
elif printf '#include <bzlib.h>\nint main(void){return !BZ2_bzlibVersion;}\n' > "$NGX_AUTOTEST.c" 2>/dev/null \
     && $CC $CC_TEST_FLAGS -o "$NGX_AUTOTEST" "$NGX_AUTOTEST.c" -lbz2 >/dev/null 2>&1; then
    rm -f "$NGX_AUTOTEST" "$NGX_AUTOTEST.c"
    CFLAGS="$CFLAGS -DXROOTD_HAVE_BZIP2=1"
    XROOTD_CODEC_LIBS="$XROOTD_CODEC_LIBS -lbz2"
    echo " + xrootd compression: bzip2 enabled (-lbz2)"
else
    rm -f "$NGX_AUTOTEST" "$NGX_AUTOTEST.c" 2>/dev/null
    echo " + xrootd compression: bzip2 disabled (install bzip2-devel to enable)"
fi

# lz4 (phase-42 extension): prefer pkg-config liblz4; else probe lz4frame.h + -llz4
# (header/lib directly, like bzip2).  Honours PKG_CONFIG_PATH so a non-system
# (e.g. conda) liblz4 is found; the runtime soname (liblz4.so.1) resolves from the
# default loader path.
if [ -n "${XROOTD_LZ4_CFLAGS:-}${XROOTD_LZ4_LIBS:-}" ]; then
    # Explicit env hint (for a non-system liblz4, e.g. conda): supply the header
    # -I via XROOTD_LZ4_CFLAGS and the link via XROOTD_LZ4_LIBS (default the bare
    # soname from the default loader path).  This avoids putting a non-system
    # prefix on PKG_CONFIG_PATH, which would flip OTHER codecs to that prefix's
    # sonames (not on the runtime path).
    CFLAGS="$CFLAGS ${XROOTD_LZ4_CFLAGS:-} -DXROOTD_HAVE_LZ4=1"
    XROOTD_CODEC_LIBS="$XROOTD_CODEC_LIBS ${XROOTD_LZ4_LIBS:--l:liblz4.so.1}"
    echo " + xrootd compression: lz4 enabled (env hint)"
elif command -v pkg-config >/dev/null 2>&1 && pkg-config --exists liblz4; then
    CFLAGS="$CFLAGS $(pkg-config --cflags liblz4) -DXROOTD_HAVE_LZ4=1"
    XROOTD_CODEC_LIBS="$XROOTD_CODEC_LIBS $(pkg-config --libs liblz4)"
    echo " + xrootd compression: lz4 enabled (pkg-config)"
elif printf '#include <lz4frame.h>\nint main(void){return !LZ4F_isError(0);}\n' > "$NGX_AUTOTEST.c" 2>/dev/null \
     && $CC $CC_TEST_FLAGS -o "$NGX_AUTOTEST" "$NGX_AUTOTEST.c" -llz4 >/dev/null 2>&1; then
    rm -f "$NGX_AUTOTEST" "$NGX_AUTOTEST.c"
    CFLAGS="$CFLAGS -DXROOTD_HAVE_LZ4=1"
    XROOTD_CODEC_LIBS="$XROOTD_CODEC_LIBS -llz4"
    echo " + xrootd compression: lz4 enabled (-llz4)"
else
    rm -f "$NGX_AUTOTEST" "$NGX_AUTOTEST.c" 2>/dev/null
    echo " + xrootd compression: lz4 disabled (install liblz4-dev to enable)"
fi

# Ceph/RADOS storage backend (phase-60): optional, header-gated.  When the
# librados dev headers + lib are present we compile src/fs/backend/rados/sd_ceph.c
# against raw librados and define -DXROOTD_HAVE_CEPH=1; otherwise sd_ceph.c
# contributes only its pure (libc-only) LFN->object-key helpers and the driver
# row in sd_registry.c is #if-compiled out, so a no-Ceph build is byte-for-byte
# unchanged.  Set XROOTD_WITHOUT_CEPH=1 to force-disable even when librados is
# present.  The link flag MUST go in ngx_module_libs (XROOTD_CEPH_LIBS, appended
# below), NOT only CORE_LIBS, or dlopen of the DYNAMIC module .so fails
# (rpm_packaging_three_packages).
XROOTD_CEPH_LIBS=""
if [ "${XROOTD_WITHOUT_CEPH:-}" != "1" ] \
   && printf '#include <rados/librados.h>\nint main(void){rados_t c; return rados_create(&c, 0);}\n' > "$NGX_AUTOTEST.c" 2>/dev/null \
   && $CC $CC_TEST_FLAGS -o "$NGX_AUTOTEST" "$NGX_AUTOTEST.c" -lrados >/dev/null 2>&1; then
    rm -f "$NGX_AUTOTEST" "$NGX_AUTOTEST.c"
    CFLAGS="$CFLAGS -DXROOTD_HAVE_CEPH=1"
    XROOTD_CEPH_LIBS="-lrados"
    echo " + xrootd storage backend: ceph/rados enabled"

    # libradosstriper — the stock XrdCeph data-plane layer (RAL/Glasgow on-RADOS
    # format compatibility). When present, the rados driver's data plane
    # (sd_ceph_striper.c) is compiled with -DXROOTD_HAVE_RADOSSTRIPER=1; otherwise
    # only the pure compat helpers (stripe naming, N2N) build, exactly like the
    # XROOTD_HAVE_CEPH gating of sd_ceph.c.
    if printf '#include <radosstriper/libradosstriper.h>\nint main(void){rados_striper_t s; (void)s; return 0;}\n' > "$NGX_AUTOTEST.c" 2>/dev/null \
       && $CC $CC_TEST_FLAGS -o "$NGX_AUTOTEST" "$NGX_AUTOTEST.c" -lradosstriper -lrados >/dev/null 2>&1; then
        rm -f "$NGX_AUTOTEST" "$NGX_AUTOTEST.c"
        CFLAGS="$CFLAGS -DXROOTD_HAVE_RADOSSTRIPER=1"
        XROOTD_CEPH_LIBS="-lradosstriper -lrados"
        echo " + xrootd storage backend: ceph/rados libradosstriper (stock XrdCeph layout) enabled"
    else
        rm -f "$NGX_AUTOTEST" "$NGX_AUTOTEST.c" 2>/dev/null
        echo " + xrootd storage backend: libradosstriper disabled (install libradosstriper-devel for stock XrdCeph layout)"
    fi
else
    rm -f "$NGX_AUTOTEST" "$NGX_AUTOTEST.c" 2>/dev/null
    echo " + xrootd storage backend: ceph/rados disabled (install librados-devel to enable)"
fi

# pblock storage backend: optional, header-gated like Ceph.  When libsqlite3 dev
# headers + lib are present we compile src/fs/backend/pblock/sd_pblock.c against
# sqlite3 and define -DXROOTD_HAVE_SQLITE=1; otherwise sd_pblock.c is empty (the
# whole file is #if XROOTD_HAVE_SQLITE) and the driver row in sd_registry.c is
# #if-compiled out, so a no-sqlite build is byte-for-byte unchanged.  Set
# XROOTD_WITHOUT_SQLITE=1 to force-disable even when sqlite3 is present.  The link
# flag MUST go in ngx_module_libs (XROOTD_SQLITE_LIBS, appended below), NOT only
# CORE_LIBS, or dlopen of the DYNAMIC module .so fails (rpm_packaging_three_packages).
XROOTD_SQLITE_LIBS=""
if [ "${XROOTD_WITHOUT_SQLITE:-}" != "1" ] \
   && printf '#include <sqlite3.h>\nint main(void){sqlite3 *d; return sqlite3_open(":memory:", &d) != 0;}\n' > "$NGX_AUTOTEST.c" 2>/dev/null \
   && $CC $CC_TEST_FLAGS -o "$NGX_AUTOTEST" "$NGX_AUTOTEST.c" -lsqlite3 >/dev/null 2>&1; then
    rm -f "$NGX_AUTOTEST" "$NGX_AUTOTEST.c"
    CFLAGS="$CFLAGS -DXROOTD_HAVE_SQLITE=1"
    XROOTD_SQLITE_LIBS="-lsqlite3"
    echo " + xrootd storage backend: pblock (sqlite) enabled"
else
    rm -f "$NGX_AUTOTEST" "$NGX_AUTOTEST.c" 2>/dev/null
    echo " + xrootd storage backend: pblock (sqlite) disabled (install libsqlite3-devel to enable)"
fi

# OpenSSL >= 3.0.0 is REQUIRED.
#   Licensing: OpenSSL 3.x is Apache-2.0, which is compatible with this project's
#   AGPL-3.0 license.  OpenSSL <= 1.1.1 ships under the legacy OpenSSL/SSLeay dual
#   license, whose advertising clause is INCOMPATIBLE with the GPL/AGPL.
#   Technical: the module also relies on OpenSSL 3.x EVP_MAC / provider APIs.
# Best-effort version gate: hard-error when a sub-3.0 OpenSSL is detected; warn
# (do not block) when the version cannot be determined here, e.g. a custom
# --with-openssl=<dir> build the add-on config cannot inspect.
_xrd_ssl_verified=""
if command -v pkg-config >/dev/null 2>&1 && pkg-config --exists openssl; then
    if pkg-config --atleast-version=3.0.0 openssl; then
        _xrd_ssl_verified=yes
        echo " + xrootd: OpenSSL $(pkg-config --modversion openssl) (>= 3.0.0, Apache-2.0) OK"
    else
        echo "ERROR: nginx-xrootd requires OpenSSL >= 3.0.0 (found" \
             "$(pkg-config --modversion openssl)). OpenSSL <= 1.1.1 uses the" \
             "OpenSSL/SSLeay license, which is incompatible with this project's" \
             "AGPL-3.0 license, and lacks the OpenSSL 3.x APIs this module uses." >&2
        exit 1
    fi
elif command -v openssl >/dev/null 2>&1; then
    _xrd_ssl_ver=$(openssl version 2>/dev/null | awk '{print $2}')
    case "$_xrd_ssl_ver" in
        3.*|[4-9].*|[1-9][0-9].*)
            _xrd_ssl_verified=yes
            echo " + xrootd: OpenSSL $_xrd_ssl_ver (>= 3.0.0, Apache-2.0) OK" ;;
        *)
            echo "ERROR: nginx-xrootd requires OpenSSL >= 3.0.0 (found" \
                 "${_xrd_ssl_ver:-unknown}). OpenSSL <= 1.1.1 uses the" \
                 "OpenSSL/SSLeay license, incompatible with AGPL-3.0, and lacks" \
                 "the OpenSSL 3.x APIs this module uses." >&2
            exit 1 ;;
    esac
fi
if [ -z "$_xrd_ssl_verified" ]; then
    echo "WARNING: could not verify the OpenSSL version (no pkg-config 'openssl'" \
         "module and no 'openssl' CLI). nginx-xrootd REQUIRES OpenSSL >= 3.0.0" \
         "(Apache-2.0); building against OpenSSL <= 1.1.1 is unsupported and" \
         "AGPL-incompatible." >&2
fi


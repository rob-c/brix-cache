# ---------------------------------------------------------------------------
# phase-47 W1: emit non-filter modules so the DYNAMIC build produces ONE
# combined .so.  A cross-.so RTLD_NOW symbol cycle
# (dashboard <-> webdav <-> metrics <-> stream) cannot dlopen as separate .so
# files, so for --add-dynamic-module we accumulate every non-filter block's
# srcs/deps/libs and emit a single combined module at the end of this file (the
# HTTP AUX filter stays its own .so).  For the static --add-module build nothing
# changes: xrd_emit_module just runs `. auto/module` per block, preserving each
# module's own type so STREAM modules land in STREAM_MODULES (not HTTP_MODULES).
xrd_dyn_srcs=""
xrd_dyn_deps=""
xrd_dyn_libs=""
xrd_emit_module() {
    if [ "$ngx_module_link" = DYNAMIC ]; then
        xrd_dyn_srcs="$xrd_dyn_srcs $ngx_module_srcs"
        xrd_dyn_deps="$xrd_dyn_deps $ngx_module_deps"
        xrd_dyn_libs="$xrd_dyn_libs $ngx_module_libs"
    else
        . auto/module
    fi
}


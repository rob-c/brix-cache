{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source scraping the nginx-xrootd /metrics endpoint",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "version": 1,
  "title": "nginx-xrootd",
  "tags": ["nginx-xrootd", "xrootd", "wlcg", "storage"],
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "proto",
        "label": "Protocol",
        "type": "custom",
        "query": "stream,webdav,s3",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Read throughput (bytes/s) by protocol",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (proto) (rate(xrootd_io_bytes_read{proto=~\"$proto\"}[5m]))",
          "legendFormat": "{{proto}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Write throughput (bytes/s) by protocol",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (proto) (rate(xrootd_io_bytes_written{proto=~\"$proto\"}[5m]))",
          "legendFormat": "{{proto}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP request rate (req/s) by status class",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status_class) (rate(xrootd_webdav_responses_total[5m]))",
          "legendFormat": "webdav {{status_class}}"
        },
        {
          "refId": "B",
          "expr": "sum by (status_class) (rate(xrootd_s3_responses_total[5m]))",
          "legendFormat": "s3 {{status_class}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "5xx error ratio (WebDAV + S3)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(xrootd_webdav_responses_total{status_class=\"5xx\"}[5m])) / clamp_min(sum(rate(xrootd_webdav_responses_total[5m])), 1)",
          "legendFormat": "webdav 5xx"
        },
        {
          "refId": "B",
          "expr": "sum(rate(xrootd_s3_responses_total{status_class=\"5xx\"}[5m])) / clamp_min(sum(rate(xrootd_s3_responses_total[5m])), 1)",
          "legendFormat": "s3 5xx"
        }
      ]
    },
    {
      "id": 5,
      "title": "I/O latency p50 / p95 / p99 (usec)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "µs" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(xrootd_io_latency_usec_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(xrootd_io_latency_usec_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(xrootd_io_latency_usec_bucket[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 6,
      "title": "Authentication outcomes (req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (rate(xrootd_webdav_auth_total[5m]))",
          "legendFormat": "webdav {{result}}"
        },
        {
          "refId": "B",
          "expr": "sum by (result) (rate(xrootd_s3_auth_total[5m]))",
          "legendFormat": "s3 {{result}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Cache hit ratio",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(xrootd_cache_hits_total[5m])) / clamp_min(sum(rate(xrootd_cache_hits_total[5m])) + sum(rate(xrootd_cache_misses_total[5m])), 1)",
          "legendFormat": "hit ratio"
        }
      ]
    },
    {
      "id": 8,
      "title": "Active connections",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(xrootd_connections_active)", "legendFormat": "active" }
      ]
    },
    {
      "id": 9,
      "title": "Rate-limit throttling (events/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(rate(xrootd_rate_limit_throttled_total[5m]))", "legendFormat": "throttled" }
      ]
    },
    {
      "id": 10,
      "title": "Per-VO egress (bytes/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (vo) (rate(xrootd_vo_bytes_tx_total[5m]))", "legendFormat": "{{vo}}" }
      ]
    },
    {
      "id": 11,
      "title": "FRM stage requests in-flight",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 30 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(xrootd_frm_in_flight)", "legendFormat": "in-flight" }
      ]
    },
    {
      "id": 12,
      "title": "Cluster servers (registered / blacklisted)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 30 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(xrootd_cluster_servers_registered)", "legendFormat": "registered" },
        { "refId": "B", "expr": "sum(xrootd_cluster_server_blacklisted)", "legendFormat": "blacklisted" }
      ]
    }
  ]
}

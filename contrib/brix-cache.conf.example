# ============================================================================
# nginx-xrootd — example server configuration
# ============================================================================
#
# This file is shipped as a *reference* (installed as brix-cache.conf.example so it
# never auto-activates).  To use it:
#
#   1. The module's load_module lines are installed separately by the RPM as
#      /etc/nginx/conf.d/mod-xrootd.conf (loaded before this file).  Confirm
#      with:  nginx -t
#
#   2. Copy this file to an ACTIVE name and edit the paths/secrets:
#        cp /etc/nginx/conf.d/brix-cache.conf.example /etc/nginx/conf.d/brix-cache.conf
#
#   3. The server blocks BELOW are HTTP-context (davs:// WebDAV + S3 + /metrics
#      + /healthz + dashboard) and load from conf.d as-is, because nginx's
#      stock nginx.conf does `include /etc/nginx/conf.d/*.conf;` INSIDE http{}.
#
#   4. The root:// XRootD protocol runs in the top-level stream{} context, which
#      conf.d cannot hold.  Paste the STREAM EXAMPLE block (commented at the very
#      bottom of this file) into your main /etc/nginx/nginx.conf, and make sure
#      that nginx.conf has `thread_pool default threads=4 max_queue=65536;` at
#      the top level (the async data-plane uses it).
#
#   5. RECOMMENDED — set a bounded shutdown timeout in the top-level nginx.conf
#      so an old worker still streaming a transfer is force-closed instead of
#      lingering. CRITICAL: keep this value BELOW the systemd unit's
#      TimeoutStopSec, or a graceful stop never completes in time and systemd
#      SIGKILLs the whole process at TimeoutStopSec on EVERY `systemctl restart`
#      (a slow, ungraceful restart). The stock nginx.service uses
#      TimeoutStopSec=5s, so for fast restarts use a small value:
#
#         worker_shutdown_timeout 2s;    # fast `systemctl restart` (stop ~2s)
#
#      Only raise it (e.g. 30s) if you ALSO raise the unit's TimeoutStopSec to
#      match (the packaged nginx-xrootd.service sets TimeoutStopSec=30) AND you
#      prefer graceful in-flight drains over fast restarts. For zero-downtime
#      CONFIG changes prefer `systemctl reload` (SIGHUP) over `restart` — it has
#      no systemd stop-timeout pressure, so a longer drain is fine there.
#
#      On `nginx -s reload`/restart this module already (a) stops its background
#      timers, (b) drops idle keepalive connections at once, and (c) sends a
#      clean retry signal to in-flight clients (root:// = clean FIN; davs:// =
#      503 + Retry-After).  The native client / FUSE driver reconnect to the new
#      worker and RESUME the transfer from the last byte (read/download) within
#      their stall window (XRDC_MAX_STALL_MS, default 30s).  Keep this timeout
#      <= that window so anything cut at the backstop still recovers; do NOT set
#      it to 0 (0 = no timeout = a stuck transfer can pin the old worker).
#
#   6. RESUMABLE UPLOADS — ON BY DEFAULT.  Every write is staged to a
#      deterministic, identity-keyed partial and committed (atomic rename) only on
#      a clean close / final chunk, so an interrupted UPLOAD resumes from where it
#      left off instead of restarting at byte 0, and a concurrent reader never sees
#      a half-written object.  Disable per server/location with:
#        * root:// (stream{}):  brix_upload_resume off;
#        * davs:// (this file):  brix_webdav_upload_resume off;
#      The native client resumes automatically (root:// reopen-in-place; davs://
#      Content-Range PUT); other clients resume davs:// via Content-Range PUT + the
#      X-Upload-Offset reported on a 409.
#
#   7. STAGING DIRECTORY — by default the partial is staged ADJACENT to the
#      destination (commit is a zero-copy atomic rename).  To stage on a separate
#      high-performance caching device (e.g. NVMe/tmpfs) in front of slower storage
#      (e.g. a CephFS POSIX mount), point it elsewhere:
#        * root:// (stream{}):  brix_stage_dir       /mnt/fastcache/xrd-stage;
#        * davs:// (this file):  brix_webdav_stage_dir /mnt/fastcache/xrd-stage;
#      Writes then land on the fast device; the close (root://) / final chunk
#      (davs://) BLOCKS until commit copies the completed object to the storage and
#      atomically renames it into place (cross-device commit), then drops the cache
#      copy — so a client only sees success once the data is durably in its final
#      location.  The stage dir must be writable by the worker; size it for your
#      concurrent-upload working set.
#      DURABILITY: a complete file is recorded with a "<partial>.commit" marker
#      before the move; if a worker dies mid-move, a worker-0 reaper finishes the
#      cache->storage move on the next startup and periodically (every 60s), so
#      complete-but-uncommitted files are tracked across restarts and always reach
#      storage.  Stale IN-PROGRESS partials (abandoned uploads, no marker) are
#      "<stagedir>/*.xrdresume.part" — glob-clean from cron, e.g.:
#        find /mnt/fastcache/xrd-stage -name '*.xrdresume.part' -mtime +1 -delete
#      NOTE: a cross-device commit copies the whole object cache->storage at close;
#      for very large objects keep the storage mount fast or expect a longer close.
#
#   8. DEFAULT GATEWAY WRITE-STAGING — a WRITABLE export whose
#      brix_storage_backend is a whole-object remote (http(s):// WebDAV or
#      s3://) cannot honour random-offset writes natively (uploads replace the
#      whole object).  If you configure NO stage tier at all, brix
#      auto-provisions one at startup — announced by a loud multi-line [warn]
#      banner — over a brix-MANAGED directory:
#        /tmp/staging/<sanitised-backend-url>     (0700, worker-owned)
#      The default is the stock tier composition, byte-identical to writing:
#        brix_stage       on;
#        brix_stage_store posix:/tmp/staging/<sanitised-backend-url>;
#      Do not place files in that directory — brix creates, fills and cleans
#      it.  Mount /tmp/staging as tmpfs if you want RAM-tier spool performance
#      (staged-but-unflushed writes then do not survive a reboot).  Point
#      brix_stage_store at a durable device instead to override, or opt out
#      with "brix_stage off" — writes must then arrive strictly sequentially
#      from offset 0 (random offsets are rejected at the protocol edge).
#      An update-open of an EXISTING backend object hydrates the spool copy
#      from the backend first (read-modify-write), so a partial overwrite
#      reassembles the full object at flush instead of truncating it.
#      NOTE: the shipped systemd unit sets PrivateTmp=true — its /tmp is
#      private to the service and DELETED on every restart; brix detects this
#      at startup and shouts a "PrivateTmp DETECTED" warning for any /tmp-
#      hosted stage/cache store.  Use a durable brix_stage_store (or
#      PrivateTmp=no) when staged writes must survive service restarts.
#      A READ cache is never required for gateway operation — random reads are
#      served by ranged GETs against the backend — so the cache tier stays
#      opt-in: add e.g. "brix_cache_store posix:/tmp/cache;" (same tmpfs note
#      applies) only when you want read-through caching.
#
# Replace every /etc/grid-security/... and /var/lib/nginx-xrootd/... path and
# every secret/issuer/audience with your site's real values before serving.
# ============================================================================


# ---------------------------------------------------------------------------
# Prometheus metrics + health probes (plain HTTP, bind to localhost or a
# scrape-only network — these expose operational state, not file data).
# ---------------------------------------------------------------------------
server {
    listen 9100;
    server_name _;

    # Prometheus scrape target (see contrib/grafana-dashboard.json +
    # contrib/prometheus-alerts.yml).
    location /metrics {
        brix_metrics on;
    }

    # Liveness/readiness probe for a load balancer or Kubernetes.
    #   GET /healthz          -> 200 {"status":"ok",...}   (liveness)
    #   GET /healthz?verbose  -> 200 + readiness checks     (shm mapped, pid, ver)
    location = /healthz {
        brix_health on;
    }
}


# ---------------------------------------------------------------------------
# WebDAV over HTTPS (davs://) — token (WLCG/JWT) AND x509 proxy-cert auth.
# This is the modern WLCG gateway endpoint.
# ---------------------------------------------------------------------------
server {
    listen 8443 ssl;
    server_name storage.example.org;

    ssl_certificate     /etc/grid-security/hostcert.pem;
    ssl_certificate_key /etc/grid-security/hostkey.pem;

    # Accept (but do not require at the TLS layer) a client proxy cert; the
    # module validates it against the trusted CA dir below.
    ssl_verify_client   optional_no_ca;
    ssl_verify_depth    10;

    # Zero-copy encrypted GET via kernel TLS (OpenSSL 3 + AES-GCM); nginx falls
    # back to read()+SSL_write automatically when kTLS is unavailable.
    ssl_conf_command Options KTLS;
    ssl_buffer_size  64k;

    client_max_body_size 0;          # allow arbitrarily large PUT/uploads
    brix_webdav_proxy_certs on;    # enable x509 proxy-cert validation

    access_log /var/log/nginx/brix_webdav_access.log;

    # Web dashboard (operational UI) — password-protected, TLS-only.
    location /xrootd/ {
        brix_dashboard on;
        brix_dashboard_password "CHANGE-ME";

        # Admin file browser: lets a signed-in admin list (name, local owner,
        # size, creation/modification dates) and download any file beneath this
        # root, straight from the dashboard.  Off unless set; admin-auth-only and
        # confined to this root via the kernel (openat2 RESOLVE_BENEATH), so a
        # client path can never escape it.  Point it at your storage export:
        #brix_dashboard_browse_root /var/lib/nginx-xrootd/data;
    }

    location / {
        root               /var/lib/nginx-xrootd/data;
        dav_methods        DELETE MKCOL;

        brix_webdav      on;
        brix_webdav_root /var/lib/nginx-xrootd/data;

        # Authentication: `optional` accepts anonymous + authenticated; use
        # `required` to reject unauthenticated requests.
        brix_webdav_auth        optional;
        brix_webdav_allow_write on;

        # Resumable uploads are ON by default (note 6).  Optionally stage on a
        # fast caching device in front of the storage (note 7); commit copies to
        # the storage mount.  Uncomment to enable, or disable resume entirely.
        #brix_webdav_stage_dir     /mnt/fastcache/xrd-stage;
        #brix_webdav_upload_resume off;

        # x509 / VOMS proxy validation against the IGTF CA dir.
        brix_webdav_cadir /etc/grid-security/certificates;

        # WLCG bearer-token (JWT) validation — JWKS is hot-reloaded on mtime.
        brix_webdav_token_jwks     /etc/nginx-xrootd/jwks.json;
        brix_webdav_token_issuer   "https://wlcg.example.org/";
        brix_webdav_token_audience "https://storage.example.org";

        # Third-party copy (TPC) — WebDAV COPY with delegated credentials.
        # tpc_cafile is a CA *bundle file* used to verify the remote TPC peer
        # (distinct from cadir above, which is the IGTF CA *directory*).
        brix_webdav_tpc on;
        brix_webdav_tpc_cafile /etc/pki/tls/certs/ca-bundle.crt;
    }
}


# ---------------------------------------------------------------------------
# S3 REST endpoint (SigV4) — plain HTTP here; front with TLS (terminate at this
# server with `listen 9001 ssl;` + ssl_certificate, or at an upstream LB).
# ---------------------------------------------------------------------------
server {
    listen 9001;
    server_name s3.example.org;

    client_max_body_size 0;
    access_log /var/log/nginx/brix_s3_access.log;

    location / {
        brix_s3            on;
        brix_s3_root       /var/lib/nginx-xrootd/data;
        brix_s3_bucket     mybucket;
        brix_s3_allow_write on;
        brix_s3_max_keys   1000;
        # SigV4 access/secret keys are configured per your credential source;
        # see docs/04-protocols/ for the S3 auth model.
    }
}


# ============================================================================
# STREAM EXAMPLE — paste into the TOP LEVEL of /etc/nginx/nginx.conf (NOT here;
# conf.d is included inside http{} and cannot contain a stream{} block).
# ============================================================================
#
# stream {
#     # RECOMMENDED HARDENING (see docs/09-developer-guide/deployment-hardening.md):
#     #   0. Run workers UNPRIVILEGED. Set a top-level `user brix;` in nginx.conf so
#     #      nginx drops workers to a dedicated account. Independently, brix FORCE-
#     #      DROPS any root-capable worker (root, or a non-root account holding
#     #      CAP_SETUID) down to `brix_worker_user` below at init — fail-closed — so
#     #      the pre-auth credential parsers (JWT/macaroon/X.509/VOMS/krb5, which run
#     #      in the worker on attacker-controlled bytes) NEVER run as a root-capable
#     #      identity. Default target is `nobody` (+ a startup warning); set a
#     #      dedicated account instead:
#     brix_worker_user brix;
#     #   1. Run under the hardened systemd unit packaging/brix-cache.service
#     #      (NoNewPrivileges, ProtectSystem=strict, PrivateDevices, RestrictNamespaces,
#     #      CapabilityBoundingSet=CAP_SETUID CAP_SETGID CAP_NET_BIND_SERVICE, ...).
#     #   2. Install the SELinux subpackage (nginx-mod-brix-cache-selinux).
#     #   3. Turn on the per-worker syscall filter below — roll out with `audit`
#     #      once (converge the audit log), then switch to `enforce`.  NOTE: `audit`
#     #      is log-only and provides NO containment; only `enforce` does.
#     brix_seccomp enforce;
#     #      execve/execveat are ALLOWED by default so features that fork+exec an
#     #      EXTERNAL helper keep working under `enforce`: the FRM "exec" MSS adapter
#     #      (tape://exec, $BRIX_FRM_STAGECMD driving a real HSM), OIDC token fetch,
#     #      native-TPC token-exchange, WebDAV HTTP-TPC oidc-agent, the kXR_prepare
#     #      hook.  If you use NONE of these, opt into the strict anti-shell posture
#     #      by KILLing execve (ptrace/process_vm_* are always killed regardless):
#     #brix_seccomp_allow_exec off;
#     #   4. If you enable per-request UNIX impersonation (`brix_impersonation map`,
#     #      docs/06-authentication/impersonation.md), point the privileged broker
#     #      at the dedicated non-root account the RPM created, so nothing runs as
#     #      root after startup:
#     #brix_impersonation             map;
#     #brix_impersonation_broker_user brix-broker;
#
#     # root:// with WLCG token auth (modern default).
#     server {
#         listen 1094;
#         xrootd            on;
#         brix_root       /var/lib/nginx-xrootd/data;
#         brix_auth       token;
#         brix_allow_write on;
#         # Resumable uploads are ON by default; optionally stage on a fast device:
#         #brix_stage_dir /mnt/fastcache/xrd-stage;
#         # io_uring disk-I/O backend is OFF by default (the thread pool is the
#         # correct, portable path).  Enable ONLY after verifying on your kernel
#         # + storage filesystem that large streamed writes complete — some
#         # kernels signal the ring's eventfd for trivial ops but never complete
#         # buffered file writes, wedging transfers after ~8 MiB.  Opt in with:
#         #brix_io_uring on;
#         brix_token_jwks     /etc/nginx-xrootd/jwks.json;
#         brix_token_issuer   "https://wlcg.example.org/";
#         brix_token_audience "https://storage.example.org";
#         brix_access_log /var/log/nginx/brix_access.log;
#     }
#
#     # roots:// with GSI/x509 + in-protocol TLS.
#     server {
#         listen 1095;
#         xrootd            on;
#         brix_root       /var/lib/nginx-xrootd/data;
#         brix_auth       gsi;
#         brix_tls        on;
#         brix_allow_write on;
#         brix_certificate     /etc/grid-security/hostcert.pem;
#         brix_certificate_key /etc/grid-security/hostkey.pem;
#         brix_trusted_ca      /etc/grid-security/certificates/ca.pem;
#         brix_access_log /var/log/nginx/brix_gsi_access.log;
#     }
# }

---
import Layout from '../layouts/Layout.astro';
import Band from '../components/Band.astro';
import Cta from '../components/Cta.astro';
import { REPO_URL } from '../lib/site';

// Client row — each speaks one protocol, tinted with that protocol's accent.
const clients = [
  { name: 'xrdcp · xrdfs · pyxrootd', scheme: 'root://', tint: 'var(--root)' },
  { name: 'curl · rucio · browser', scheme: 'davs://', tint: 'var(--dav)' },
  { name: 'aws-cli · boto3', scheme: 's3://', tint: 'var(--s3)' },
  { name: 'globus-url-copy · gfal2 · fts', scheme: 'gsiftp://', tint: 'var(--ftp)' },
];

// Headline numbers for the hero stat strip — all defensible from the tree.
const stats = [
  { n: '4', l: 'wire protocols', s: 'root · dav · s3 · gsiftp' },
  { n: '32', l: 'XRootD opcodes', s: 'the full 5.2 verb set' },
  { n: '1', l: 'nginx binary', s: 'one event loop' },
  { n: '~8.7k', l: 'tests', s: 'cross-checked vs. stock' },
];

// Recently landed — the headline work of 2026. Each carries an honest status:
// "Landed" = shipped and tested; "Native-tested" / "Code-complete" flag work
// whose full container-fleet or live-cluster verification is infra-blocked.
const recent = [
  {
    t: 'A GridFTP door',
    tint: 'var(--ftp)',
    status: 'Landed · native-interop tested',
    d: 'A full gsiftp:// GridFTP server: GSI / X.509 control-channel auth, parallel MODE E data streams, encrypted (PROT P) data channels, and server-to-server third-party copy — every transfer bridged onto the same POSIX tree, or delegated onward to a root:// origin as the user.',
    cite: 'src/protocols/gridftp/ev/ · tests/test_gridftp_gsiftp_ev.py',
  },
  {
    t: 'Identity survives the hop',
    tint: 'var(--root)',
    status: 'Landed · opt-in',
    d: 'Each authenticated request reaches the storage origin under its own identity — a per-user GSI proxy, WLCG token, S3 SigV4 key, or CephX keyring — with opt-in minting of short-lived x509 proxies for bearer-only clients. Stock XRootD collapses every proxied request onto one service credential.',
    cite: 'src/fs/backend/cred_mint.c · vfs_staged.c',
  },
  {
    t: 'Real cmsd cluster parity',
    tint: 'var(--dav)',
    status: 'Landed · wire-tested',
    d: 'BriX-Cache speaks the genuine XrdCms / cmsd cluster-management wire: manager ↔ server selection by real load, dynamic file location, forwarded staging, and multi-replica delete fan-out — drop-in interop with an existing XRootD cmsd mesh, every step flag-gated to legacy behaviour by default.',
    cite: 'src/net/cms/ · tests/test_cms_*.py',
  },
  {
    t: 'Write paths that fail closed',
    tint: 'var(--s3)',
    status: 'Landed',
    d: 'Every write path — WebDAV PUT, S3 PutObject, GridFTP STOR, native kXR_write / pgwrite, and TPC commit legs — gained fail-closed truncation guards plus opt-in end-to-end digest verification, each found and pinned with a userland TCP fault injector that corrupts and truncates the wire on purpose.',
    cite: 'tests/resilience/ · docs/07-security/hostile-network-lessons.md',
  },
  {
    t: 'CVMFS, client and cache',
    tint: 'var(--root)',
    status: 'Landed',
    d: 'A clean-room native CVMFS client with live-repo signature verification, a FUSE writable overlay over a read-only mount, and stock-style on-demand /cvmfs/<repo> automounting with no autofs kernel module or systemd dependency — works unprivileged, in containers, on WSL2.',
    cite: 'client/apps/fs/ · docs/05-operations/cvmfs-automount.md',
  },
  {
    t: 'Ceph / RADOS, natively',
    tint: 'var(--dav)',
    status: 'Code-complete · live lab pending',
    d: 'RADOS object storage as a first-class backend — striper-aware I/O, per-user CephX credentials, staged writes, and hierarchical directory listing projected over a flat key namespace — reached through the same VFS seam as every other backend.',
    cite: 'src/fs/backend/rados/ · tests/run_rados_parity.sh',
  },
];

const DEVGUIDE_URL = `${REPO_URL}/blob/main/docs/09-developer-guide/development-history.md`;

// The seven src/ concept buckets — the shape of the codebase.
const buckets = [
  ['core', 'nginx plumbing — compat, types, config, shm, async io/uring', 'var(--root)'],
  ['protocols', 'one folder per wire protocol — root, webdav, s3, ssi, srr, dig', 'var(--dav)'],
  ['auth', 'identity & authz — gsi, token, sss, krb5, voms, crypto, impersonate', 'var(--s3)'],
  ['fs', 'the VFS — sole storage truth: confine, backends, cache, tier, xfer', 'var(--root)'],
  ['net', 'scale-out — cms, manager, upstream, proxy, ratelimit, tap, mirror', 'var(--dav)'],
  ['observability', 'metrics, accesslog, dashboard, pmark', 'var(--s3)'],
  ['tpc', 'third-party copy — cross-plane by nature', 'var(--root)'],
];

const backends = [
  { name: 'POSIX disk', sub: 'pread / pwrite / sendfile', tint: 'var(--root)' },
  { name: 'RADOS · CephFS', sub: 'object + striper', tint: 'var(--dav)' },
  { name: 'HTTP / remote origin', sub: 'read-through cache fill', tint: 'var(--s3)' },
  { name: 'Stage · tier', sub: 'nearline / recall', tint: 'var(--panel)' },
];
---

<Layout
  title="About"
  description="How BriX-Cache is built: four protocol front-ends — root://, WebDAV, S3, and a gsiftp:// GridFTP gateway — over one shared auth-and-cache core and a VFS that is the sole storage truth, all inside a single nginx binary. A full architecture diagram of the project."
  accent="dav"
>
  <!-- HERO -->
  <Band first={true}>
    <span class="eyebrow">About the project</span>
    <h1 class="display hero-head">One binary.<br />Four protocols.<br />One path to disk.</h1>
    <p class="lede">
      BriX-Cache is a single nginx module that speaks <span class="mono">root://</span> (XRootD),
      WebDAV, and S3 off the same POSIX tree — and now terminates a full <span class="mono">gsiftp://</span>
      GridFTP server besides. Every request enters nginx's event loop, passes one shared core that
      decides auth and handles caching &amp; metrics, then reaches storage through a VFS where all raw
      file I/O lives in exactly one place.
    </p>
    <dl class="stats" aria-label="Project at a glance">
      {stats.map((x) => (
        <div class="stat">
          <dt class="stat-n mono">{x.n}</dt>
          <dd class="stat-l">{x.l}<span class="stat-s mono">{x.s}</span></dd>
        </div>
      ))}
    </dl>
  </Band>

  <!-- RECENTLY LANDED -->
  <Band variant="ink" id="recent">
    <span class="eyebrow">Recently landed</span>
    <h2 class="display sect-head">What shipped this year.</h2>
    <p class="lede muted intro recent-intro">
      The project moves in phases, and 2026 has been a heavy one — a fourth protocol, identity that
      survives the proxy hop, real cluster-management parity, and a write path hardened against a
      hostile wire. Each card carries an honest status.
    </p>
    <div class="grid grid-3 rgrid">
      {recent.map((r) => (
        <article class="panel panel--hover rcard" style={`--tint:${r.tint}`}>
          <span class="rstatus mono">{r.status}</span>
          <h3 class="rcard-t">{r.t}</h3>
          <p class="muted rcard-d">{r.d}</p>
          <p class="mono rcard-cite">{r.cite}</p>
        </article>
      ))}
    </div>
    <p class="recent-more mono">
      The full phase-by-phase record lives in the tree: <a href={DEVGUIDE_URL}>docs · development-history.md ↗</a>
    </p>
  </Band>

  <!-- THE DIAGRAM -->
  <Band variant="sunken" id="diagram">
    <span class="eyebrow">The architecture</span>
    <h2 class="display sect-head">The whole system, one picture.</h2>

    <div class="diagram" role="img"
      aria-label="Architecture: clients speaking root, WebDAV, S3 and gsiftp enter nginx; stream and http blocks front-end each protocol; all converge on a shared core, then a VFS, then storage backends.">

      <!-- L0 clients -->
      <div class="layer-tag">clients</div>
      <div class="row row-4">
        {clients.map((c) => (
          <div class="node" style={`--tint:${c.tint}`}>
            <b>{c.name}</b>
            <span class="chip" style={`background:${c.tint}`}>{c.scheme}</span>
          </div>
        ))}
      </div>

      <div class="arrow"><span>▼ TCP · TLS · HTTP(S)</span></div>

      <!-- L1 nginx process -->
      <div class="nginx">
        <div class="nginx-tag">nginx · single binary · non-blocking workers</div>
        <div class="lanes">
          <div class="lane" style="--tint:var(--root)">
            <div class="lane-h mono">stream {'{}'} block</div>
            <div class="node" style="--tint:var(--root)"><b>Native root:// handler</b><small>open · read · pgread · write · stat · 32 opcodes</small></div>
            <div class="node" style="--tint:var(--ftp)"><b>GridFTP gateway</b><small>gsiftp · GSI · MODE E · TPC</small></div>
            <div class="node" style="--tint:var(--root)"><b>Transparent proxy / relay</b><small>tap · mirror · handoff</small></div>
          </div>
          <div class="lane" style="--tint:var(--dav)">
            <div class="lane-h mono">http {'{}'} block</div>
            <div class="node" style="--tint:var(--dav)"><b>WebDAV handler</b><small>GET · PUT · PROPFIND · COPY · MOVE · LOCK · TPC</small></div>
            <div class="node" style="--tint:var(--s3)"><b>S3 handler</b><small>SigV4 · ListObjectsV2 · multipart</small></div>
            <div class="node" style="--tint:var(--panel)"><b>/metrics · /brix dashboard</b><small>Prometheus · live operator view</small></div>
          </div>
        </div>
      </div>

      <div class="arrow"><span>▼ one shared module core</span></div>

      <!-- L2 shared core -->
      <div class="bar bar--core">
        <b>Shared core</b>
        <div class="bar-items">
          {['auth gate', 'path confinement', 'cache', 'tier / stage', 'metrics', 'access log'].map((i) => (
            <span class="pill mono">{i}</span>
          ))}
        </div>
      </div>

      <div class="arrow"><span>▼ the one storage seam</span></div>

      <!-- L3 VFS -->
      <div class="bar bar--vfs">
        <b>VFS — sole storage truth</b>
        <span class="mono vfs-sub">bytes · namespace · metadata · capability-typed driver</span>
      </div>

      <div class="arrow"><span>▼ pluggable backends</span></div>

      <!-- L4 backends -->
      <div class="row row-4">
        {backends.map((b) => (
          <div class="node node--ink" style={`--tint:${b.tint}`}>
            <b>{b.name}</b>
            <small>{b.sub}</small>
          </div>
        ))}
      </div>
    </div>
  </Band>

  <!-- SEVEN BUCKETS -->
  <Band id="buckets">
    <span class="eyebrow">The codebase</span>
    <h2 class="display sect-head">Seven concept buckets under <span class="mono">src/</span>.</h2>
    <p class="lede muted intro">
      The source is sorted by concept, not by protocol — so shared behaviour is written once and
      reused across every front-end. Cross-directory includes are src-rooted.
    </p>
    <div class="grid grid-3 bgrid">
      {buckets.map(([name, blurb, tint]) => (
        <article class="panel panel--hover bucket" style={`--tint:${tint}`}>
          <span class="chip" style={`background:${tint}`}>{name}/</span>
          <p class="muted bucket-blurb">{blurb}</p>
        </article>
      ))}
    </div>
  </Band>

  <!-- INVARIANTS -->
  <Band variant="ink" id="invariants">
    <span class="eyebrow">What holds it together</span>
    <h2 class="display sect-head">Rules the whole system keeps.</h2>
    <div class="grid grid-2">
      <div class="panel panel--hover"><b class="inv-h">Auth before a byte moves</b><p class="muted">GSI/x509 with request signing, WLCG tokens with per-path scope, SSS, host, password, krb5 — decided once, in one gate.</p></div>
      <div class="panel panel--hover"><b class="inv-h">One storage seam</b><p class="muted">Raw <span class="mono">pread</span>/<span class="mono">pwrite</span>/<span class="mono">sendfile</span> exist only in <span class="mono">src/fs/backend/</span>. Everything above speaks to the VFS.</p></div>
      <div class="panel panel--hover"><b class="inv-h">No worker ever blocks</b><p class="muted">Disk syscalls run on a thread pool; the worker keeps framing protocol and servicing sockets.</p></div>
      <div class="panel panel--hover"><b class="inv-h">Tested against the reference</b><p class="muted">Whole test modules run unchanged against BriX-Cache and stock xrootd. Any divergence in status or bytes is a failure.</p></div>
    </div>
  </Band>

  <Band>
    <Cta
      title="Read the source, not just the diagram."
      note="AGPL-3.0-only. The developer guide carries the operation-to-file map and the full architecture deep-dive."
    />
  </Band>
</Layout>

<style>
  .hero-head { margin: 0.6rem 0 1.2rem; max-width: 14ch; }
  .sect-head { margin: 0.5rem 0 1.4rem; max-width: 26ch; }
  .intro { margin-bottom: 1.8rem; max-width: 62ch; }

  /* hero stat strip */
  .stats {
    margin-top: 2rem; display: grid; gap: 0;
    grid-template-columns: repeat(2, 1fr); border: var(--border); box-shadow: var(--shadow-sm);
  }
  @media (min-width: 720px) { .stats { grid-template-columns: repeat(4, 1fr); } }
  .stat {
    display: flex; flex-direction: column; gap: 0.15rem;
    padding: 1rem 1.15rem; border-right: var(--border-2); border-bottom: var(--border-2);
    background: var(--panel);
  }
  @media (min-width: 720px) { .stat { border-bottom: none; } .stat:last-child { border-right: none; } }
  .stat-n {
    font-family: var(--display); font-stretch: 125%; font-weight: 800;
    font-size: clamp(2rem, 4.5vw, 2.8rem); line-height: 0.95; letter-spacing: -0.03em;
  }
  .stat-l { font-weight: 700; font-size: 0.9rem; display: flex; flex-direction: column; gap: 0.1rem; }
  .stat-s { font-weight: 400; font-size: 0.7rem; color: var(--ink-2); }

  /* recently landed */
  .recent-intro { max-width: 60ch; }
  .rgrid { align-items: stretch; margin-top: 0.4rem; }
  .rcard {
    display: flex; flex-direction: column; gap: 0.55rem; height: 100%;
    border-top: 9px solid var(--tint);
  }
  .rstatus {
    align-self: flex-start; font-size: 0.62rem; font-weight: 700;
    letter-spacing: 0.06em; text-transform: uppercase;
    border: var(--border-2); border-color: var(--tint); color: var(--paper);
    padding: 0.18em 0.55em;
  }
  .rcard-t {
    font-family: var(--display); font-stretch: 112%; font-weight: 700;
    font-size: 1.28rem; line-height: 1.05;
  }
  .rcard-d { font-size: 0.9rem; }
  .rcard-cite { margin-top: auto; font-size: 0.7rem; color: #a8a29e; word-break: break-word; }
  .recent-more { margin-top: 1.8rem; font-size: 0.85rem; }
  .recent-more a { color: var(--accent); }

  /* ---- diagram ---- */
  .diagram { display: flex; flex-direction: column; align-items: stretch; gap: 0; }
  .layer-tag {
    font-family: var(--mono); font-size: 0.72rem; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--ink-2); margin-bottom: 0.6rem;
  }
  .row { display: grid; gap: 0.9rem; }
  @media (min-width: 720px) {
    .row-3 { grid-template-columns: repeat(3, 1fr); }
    .row-4 { grid-template-columns: repeat(4, 1fr); }
  }

  .node {
    background: var(--panel); border: var(--border); box-shadow: var(--shadow-sm);
    border-left: 10px solid var(--tint); padding: 0.8rem 0.9rem;
    display: flex; flex-direction: column; gap: 0.4rem;
  }
  .node b { font-size: 0.98rem; }
  .node small { font-family: var(--mono); font-size: 0.72rem; color: var(--ink-2); }
  .node .chip { align-self: flex-start; font-size: 0.8rem; }
  .node--ink { background: var(--ink); color: var(--paper); box-shadow: 4px 4px 0 var(--tint); }
  .node--ink small { color: #a8a29e; }

  .arrow {
    display: flex; justify-content: center; padding: 0.7rem 0;
  }
  .arrow span {
    font-family: var(--mono); font-size: 0.74rem; font-weight: 600; color: var(--ink-2);
    letter-spacing: 0.02em;
  }

  /* nginx container */
  .nginx {
    border: var(--border); box-shadow: var(--shadow); background: var(--panel);
    padding: 1.1rem; position: relative;
  }
  .nginx-tag {
    position: absolute; top: -0.9rem; left: 1rem; background: var(--ink); color: var(--paper);
    font-family: var(--mono); font-size: 0.72rem; font-weight: 600; padding: 0.25em 0.7em;
    border: var(--border-2);
  }
  .lanes { display: grid; gap: 1rem; margin-top: 0.5rem; }
  @media (min-width: 820px) { .lanes { grid-template-columns: 1fr 1.6fr; } }
  .lane {
    border: var(--border-2); border-left: 10px solid var(--tint); background: var(--band);
    padding: 0.8rem; display: flex; flex-direction: column; gap: 0.7rem;
  }
  .lane-h { font-size: 0.78rem; font-weight: 600; color: var(--ink); }

  /* full-width bars */
  .bar {
    border: var(--border); box-shadow: var(--shadow-sm); padding: 1rem 1.2rem;
    display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
  }
  .bar b { font-family: var(--display); font-stretch: 112%; font-size: 1.2rem; }
  .bar--core { background: var(--panel); }
  .bar--vfs { background: var(--accent); }
  .bar-items { display: flex; gap: 0.45rem; flex-wrap: wrap; }
  .pill { border: var(--border-2); background: var(--panel); padding: 0.22em 0.6em; font-size: 0.76rem; font-weight: 600; }
  .vfs-sub { font-size: 0.8rem; }

  /* ---- buckets ---- */
  .bgrid { align-items: stretch; }
  .bucket { display: flex; flex-direction: column; gap: 0.6rem; border-left: 10px solid var(--tint); height: 100%; }
  .bucket .chip { align-self: flex-start; }
  .bucket-blurb { font-size: 0.9rem; }

  .inv-h { font-family: var(--display); font-stretch: 112%; font-size: 1.15rem; display: block; margin-bottom: 0.5rem; }
</style>

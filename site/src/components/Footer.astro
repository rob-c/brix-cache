---
import { url, REPO_URL, DOCS_URL, LICENSE, AUDIENCES, PROTOCOLS } from '../lib/site';
---

<footer class="band band--ink band-pad">
  <div class="wrap foot">
    <div class="foot-brand">
      <span class="display foot-word">gnuBall</span>
      <p class="muted foot-tag">The whole HEP data stack in one nginx binary.</p>
      <p class="foot-chips">
        {PROTOCOLS.map((p) => <span class:list={['chip', `chip--${p.id}`]}>{p.scheme}</span>)}
      </p>
    </div>

    <nav class="foot-col" aria-label="Who it's for">
      <span class="foot-h">Who it's for</span>
      {AUDIENCES.map((a) => <a href={url(a.href)}>{a.label}</a>)}
    </nav>

    <nav class="foot-col" aria-label="Project">
      <span class="foot-h">Project</span>
      <a href={DOCS_URL}>Documentation</a>
      <a href={REPO_URL}>Source on GitHub</a>
      <a href={`${REPO_URL}/blob/main/LICENSE`}>License · {LICENSE}</a>
    </nav>
  </div>
  <div class="wrap foot-rule">
    <span class="mono">{LICENSE}</span>
    <span class="mono muted">github.com/rob-c/nginx-xrootd</span>
  </div>
</footer>

<style>
  .foot {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) {
    .foot { grid-template-columns: 2fr 1fr 1fr; }
  }
  .foot-word { font-size: 2rem; }
  .foot-tag { margin-top: 0.5rem; max-width: 34ch; }
  .foot-chips { margin-top: 1rem; display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .foot-col { display: flex; flex-direction: column; gap: 0.55rem; }
  .foot-col a { font-family: var(--mono); font-size: 0.85rem; text-decoration: none; color: var(--paper); }
  .foot-col a:hover { color: var(--accent); text-decoration: underline; }
  .foot-h {
    font-family: var(--mono); font-size: 0.72rem; letter-spacing: 0.14em;
    text-transform: uppercase; color: #a8a29e; margin-bottom: 0.3rem;
  }
  .foot-rule {
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;
    margin-top: 2.4rem; padding-top: 1.1rem; border-top: 2px solid #3f3f3f;
    font-size: 0.8rem;
  }
</style>

# deploy/cvmfs/docker/nginx.conf.in — the CVMFS site-cache demo, one config.
#
# One nginx serves three ports:
#   :3128  the CVMFS site cache (forward-proxy mode) + bad-actor guard
#   :3129  the operator dashboard
#   :3130  Prometheus /metrics + /healthz
#
# Cached CVMFS data lands in /var/cache/cvmfs (a docker VOLUME) — inspect it
# live with:  docker exec cvmfs-demo find /var/cache/cvmfs -type f
#
# entrypoint.sh renders @DASH_PASSWORD@ and @UPSTREAM_ALLOW@ from the env.

worker_processes auto;
error_log /var/log/nginx-xrootd/error.log info;
pid /run/nginx-xrootd.pid;

thread_pool default threads=8;      # cache fills run off the event loop
events { worker_connections 4096; }

http {
    log_format cvmfs '$remote_addr [$time_local] "$request" $status '
                     '$body_bytes_sent class=$cvmfs_class cache=$cvmfs_cache '
                     'origin=$cvmfs_origin';

    # ---- :3128  the CVMFS site cache --------------------------------------
    # CVMFS clients set CVMFS_HTTP_PROXY to this port and send absolute-form
    # request lines; the target Stratum-1 must be on the allowlist. The
    # listener/keepalive shape keeps a worker node's pooled proxy connection
    # alive (never recycle it early) — proven by tests/run_cvmfs_keepalive.sh.
    server {
        listen 3128 so_keepalive=60s:10s:6 backlog=2048;
        keepalive_timeout 3600s; keepalive_requests 1000000;
        send_timeout 300s; client_header_timeout 300s;
        reset_timedout_connection off;
        access_log /var/log/nginx-xrootd/cvmfs_access.log cvmfs;

        location / {
            xrootd_cvmfs on;
            xrootd_cvmfs_cache_store posix:/var/cache/cvmfs;   # <-- cached data
            xrootd_cache_verify cvmfs-cas;                     # verify on fill

            # This site's Stratum-1s (host-only match, any port). One line,
            # space-separated — the geo API picks the closest for each client.
            xrootd_cvmfs_upstream_allow @UPSTREAM_ALLOW@;
            xrootd_cvmfs_upstream_max 16;    # >= number of allowed hosts

            # never-drop: hold+retry a fill for 25s (< the client's timeout).
            xrootd_cvmfs_client_hold 25;

            # bounce junk before the handler; one audit line per signal so
            # fail2ban can ban probers. 403 keeps the no-broken-socket contract.
            xrootd_guard on;
            xrootd_guard_bounce_status 403;
            xrootd_guard_audit_log /var/log/nginx-xrootd/guard-audit.log;
            xrootd_guard_valid_prefix /cvmfs;
            xrootd_guard_valid_method GET HEAD;
        }
    }

    # ---- :3129  operator dashboard (firewall this port in production) -----
    server {
        listen 3129;
        location /xrootd/ {
            xrootd_dashboard on;
            xrootd_dashboard_password "@DASH_PASSWORD@";
        }
        location = / { return 302 /xrootd/; }
    }

    # ---- :3130  Prometheus scrape + liveness ------------------------------
    server {
        listen 3130;
        location = /metrics { xrootd_metrics on; }
        location = /healthz { xrootd_health on; }
    }
}

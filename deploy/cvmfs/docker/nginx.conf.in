# deploy/cvmfs/docker/nginx.conf.in — the CVMFS site-cache demo, one config.
#
# One nginx serves three ports:
#   :3128  the CVMFS site cache (forward-proxy mode) + bad-actor guard
#   :3129  the operator dashboard
#   :3130  Prometheus /metrics + /healthz
#
# Cached CVMFS data lands in /var/cache/cvmfs (a docker VOLUME) — inspect it
# live with:  docker exec cvmfs-demo find /var/cache/cvmfs -type f
#
# entrypoint.sh renders @DASH_PASSWORD@ and @UPSTREAM_ALLOW@ from the env.

worker_processes auto;
error_log /var/log/nginx-xrootd/error.log info;
pid /run/nginx-xrootd.pid;

thread_pool default threads=8;      # cache fills run off the event loop
events { worker_connections 4096; }

http {
    log_format cvmfs '$remote_addr [$time_local] "$request" $status '
                     '$body_bytes_sent class=$cvmfs_class cache=$cvmfs_cache '
                     'origin=$cvmfs_origin';

    # ---- :3128  the CVMFS site cache --------------------------------------
    # CVMFS clients set CVMFS_HTTP_PROXY to this port and send absolute-form
    # request lines; the target Stratum-1 must be on the allowlist. The
    # listener/keepalive shape keeps a worker node's pooled proxy connection
    # alive (never recycle it early) — proven by tests/run_cvmfs_keepalive.sh.
    server {
        listen 3128 so_keepalive=60s:10s:6 backlog=2048;
        keepalive_timeout 3600s; keepalive_requests 1000000;
        send_timeout 300s; client_header_timeout 300s;
        reset_timedout_connection off;
        access_log /var/log/nginx-xrootd/cvmfs_access.log cvmfs;

        location / {
            brix_cvmfs on;
            brix_cache_store posix:/var/cache/cvmfs;   # <-- cached data
            brix_cache_verify cvmfs-cas;                     # verify on fill

            # Security allowlist: which Stratum-1 authorities a client may name
            # in an absolute-form request (host-only match, any port). Broad is
            # fine — it does NOT decide where we fetch from (that's the origin
            # set below). One line, space-separated.
            brix_cvmfs_upstream_allow @UPSTREAM_ALLOW@;
            brix_cvmfs_upstream_max 16;

            # ---- keep the client pinned + hide origin flakiness (2026-07-03) --
            # A worker node's CVMFS_TIMEOUT is ~5s; when a Stratum-1 goes slow
            # the client fails the object over to the next server in its list —
            # to far mirrors (CN/AU), re-fetching cold, and eventually marking
            # this proxy bad and going DIRECT. These settings keep every request
            # succeeding from here so the client never leaves:

            # 1. ONE ranked, near-first origin set (RAL → CERN → BNL). unified
            #    origin serves EVERY client-named Stratum-1 from this set, so a
            #    dead/slow origin is hidden by internal failover — the client
            #    always gets 200 from the host it chose and never wanders. The
            #    "|"-list is the ranked failover order; @ORIGINS@ is rendered
            #    from $ORIGINS (default: the allowlist hosts on :8000).
            brix_storage_backend "@ORIGINS@";
            brix_cvmfs_unified_origin on;

            # 2. Answer the geo API ourselves, RTT-ranked from this cache's
            #    vantage, so the client's PREFERRED server is the near one (RAL)
            #    to begin with.
            brix_cvmfs_geo_answer rtt;

            # 3. Fast-fail a STUCK origin (blackholed connect, or connected but
            #    no data) so failover to the next origin lands inside the 5s
            #    client window — but PROGRESS-based, not a wall-clock cap: a
            #    large catalog that is actively downloading (multi-MB, >2s over a
            #    WAN) must be allowed to finish, so we bound *no-progress* time,
            #    not total time. (Do NOT use brix_cvmfs_origin_attempt_timeout
            #    here — its hard total cap aborts large catalogs mid-transfer.)
            #    client_hold sits just below the client's CVMFS_TIMEOUT so our
            #    keep-alive 504+Retry-After (which the client's own retry
            #    coalesces onto the still-running fill) fires before the client
            #    abandons the connection.
            brix_cvmfs_origin_connect_timeout 1;   # cap a blackholed connect
            brix_cvmfs_origin_stall_timeout   2;   # no progress for 2s = stuck
            brix_cvmfs_origin_stall_bytes     1;   # ...below 1 B/s = stuck
            brix_cvmfs_client_hold            4;   # < the WN CVMFS_TIMEOUT (~5s)

            # bounce junk before the handler; one audit line per signal so
            # fail2ban can ban probers. 403 keeps the no-broken-socket contract.
            brix_guard on;
            brix_guard_bounce_status 403;
            brix_guard_audit_log /var/log/nginx-xrootd/guard-audit.log;
            brix_guard_valid_prefix /cvmfs;
            brix_guard_valid_method GET HEAD;
        }
    }

    # ---- :3129  operator dashboard (firewall this port in production) -----
    server {
        listen 3129;
        location /brix/ {
            brix_dashboard on;
            brix_dashboard_password "@DASH_PASSWORD@";

            # Make the cached CVMFS data browsable in the dashboard's "Files"
            # tab (admin-auth only; kernel-confined to this root via openat2
            # RESOLVE_BENEATH). This is the SAME directory the :3128 cache
            # writes to (brix_cache_store), so an operator sees the
            # actual on-disk cache contents. It is a content-addressed store:
            # entries are hash-sharded (e.g. /ab/cdef…), not /cvmfs logical
            # paths. entrypoint.sh pre-creates + chowns it to nobody, so this
            # realpath() resolves at config load and the workers can read it.
            brix_dashboard_browse_root /var/cache/cvmfs;
        }
        location = / { return 302 /brix/; }
    }

    # ---- :3130  Prometheus scrape + liveness ------------------------------
    server {
        listen 3130;
        location = /metrics { brix_metrics on; }
        location = /healthz { brix_health on; }
    }
}

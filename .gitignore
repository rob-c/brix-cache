# nginx build artifacts (built out-of-tree, but just in case)
objs/
*.o
*.a

# C build artifacts (client + shared + test harnesses)
*.d
!*.d/
*.so
*.pc

# Compiled native-client binaries + test harnesses all land under client/bin/
client/bin/

# mcp-workspace runtime logs
logs/

# Python
__pycache__/
*.pyc
*.pyo

# editor
*.swp
.DS_Store

# clangd / clang-tidy: the per-file compile DB is machine-specific (absolute
# paths into /tmp/nginx-1.28.3) and regenerable via
# tools/clangd/gen_compile_commands.py; .cache/ is clangd's local index. The
# committed .clangd file carries the portable fallback include/define flags.
/compile_commands.json
.cache/

# local scratch output
.tmp/
.rpmbuild/

# local agent and test caches
.aider*
.aider*/
.opencode/
.ralph/
.claude/
.codex/
.pytest_cache/
.venv/
.venv*/

# URL-shaped paths accidentally created by WebDAV/xrdcp test transfers
davs:/
tests/davs:/

# Local helper scripts not for upstream (PoCs, fuzzer, scratch) — but the
# guard/hook/IDE infrastructure IS upstream: CI and other clones need it.
tools/*
!tools/ci/
!tools/git-hooks/
!tools/clangd/
!tools/gen-docs.sh
.aider*

.rpmbuild/
.tmp/

# open-agent-kit: Team
.oak/ci/
.oak/config.*.yaml

# open-agent-kit: Issue raw JSON (local debugging only)
oak
node_modules

# Doxygen generated API docs (run tools/gen-docs.sh)
docs/doxygen/

# Local security proof-of-concept (exploit code; kept out of the repo)
xrootd-session-hijack-poc/

# superpowers brainstorm scratch
.superpowers/

# compiled fuzz harnesses + the copied server binary in the remote suite
tests/fuzz/fuzz_b64url
tests/fuzz/fuzz_safe_size
tests/fuzz/fuzz_zip_dir
k8s-tests/remote-suite/tests/fuzz/fuzz_b64url
k8s-tests/remote-suite/tests/fuzz/fuzz_safe_size
k8s-tests/remote-suite/tests/fuzz/fuzz_zip_dir
k8s-tests/remote-suite/tests/nginx-bin

# versioned shared-lib artifacts (the *.so pattern misses these)
client/libbrix.so.*

# committed-by-accident compiled server binary
tests/nginx-bin

# one-off test-transfer outputs / audit scratch (purged from history 2026-07-05 —
# keep them from ever being re-committed)
bridge_*.bin
bridge_*.txt
eos-write-test.txt
mcp-test-output.txt
/table_body.txt
/sorted_table_body*.txt
/cleaned_table.txt
/current_files.txt
/full_test_files.txt
/mapped_files.txt
/test_files_list.txt
/codebase_audit.list

# actual exploit/attack code — NEVER commit (kept local like xrootd-session-hijack-poc)
bind-exploit.bak/
# large prebuilt python wheel (fetch locally, don't vendor)
*.whl

# local agent/tooling state (never project content)
.omo/
.sisyphus/
opencode.json
/package.json
/package-lock.json
/node_modules/

#compdef xrdcp xrdfs xrddiag xrdcksum xrd xrdprep xrdgsiproxy xrdsssadmin brixMount xrdstorascan xrdcrc32c xrdcrc64 xrdadler32 xrdckverify xrdcinfo xrootdfs

# _brix-client — zsh completion for the brix client CLI suite.
#
# WHAT: Provides subcommand, flag, and enum-value completions for every brix
#       CLI tool, mirroring the coverage of brix-tools.bash.
# WHY:  Native zsh completions offer enum filtering, argument descriptions,
#       and better integration with zsh's _arguments framework.
# HOW:  Single file, #compdef on all tool names; dispatch on $words[1].
#
# Install:
#   Copy to a directory in $fpath (e.g. /usr/share/zsh/site-functions/_brix-client),
#   or source directly: autoload -U _brix-client && compdef _brix-client xrdcp xrdfs ...

_brix-client() {
    case ${words[1]} in
    (xrdcp)                              _brix_xrdcp ;;
    (xrdfs)                              _brix_xrdfs ;;
    (xrddiag)                            _brix_xrddiag ;;
    (xrdcksum)                           _brix_xrdcksum ;;
    (xrdcrc32c|xrdcrc64|xrdadler32)      _brix_cksum_hash ;;
    (xrdckverify)                        _brix_xrdckverify ;;
    (xrdcinfo)                           _brix_xrdcinfo ;;
    (xrd)                                _brix_xrd ;;
    (xrdprep)                            _brix_xrdprep ;;
    (xrdgsiproxy)                        _brix_xrdgsiproxy ;;
    (xrdsssadmin)                        _brix_xrdsssadmin ;;
    (brixMount)                          _brix_brixMount ;;
    (xrdstorascan)                       _brix_xrdstorascan ;;
    (xrootdfs)                           _brix_xrootdfs ;;
    esac
}

# ---------------------------------------------------------------------------
# xrdcp
# ---------------------------------------------------------------------------
_brix_xrdcp() {
    _arguments -S \
        '-f[overwrite existing destination]' \
        '-r[recursively copy a tree]' \
        '(-P --posc)'{-P,--posc}'[persist-on-successful-close (upload)]' \
        '-s[silent: suppress all non-error output]' \
        '(-v -d --verbose --debug)'{-v,-d,--verbose,--debug}'[verbose/debug output]' \
        '(-N --no-progress)'{-N,--no-progress}'[suppress progress bar]' \
        '--progress[show transfer progress bar]' \
        '--from=[read source list from manifest file]:manifest:_files' \
        '--journal=[record completed transfers to file]:journal:_files' \
        '--resume[shorthand for --journal <manifest>.journal (requires --from)]' \
        '--retry=[retry each failed transfer N times]:retries' \
        '--no-retry[fail immediately on first fault, no reconnect]' \
        '--max-stall=[reconnect patience window in milliseconds]:ms' \
        '--auto-refresh[proactively renew expired token or proxy]' \
        '--oidc-account=[oidc-agent account for --auto-refresh]:account' \
        '(-j --jobs)'{-j+,--jobs=}'[copy up to N files concurrently]:n' \
        '--sync[skip destinations with matching size (or per --sync-check)]' \
        '--sync-check=[destination comparison mode for --sync]:mode:(size mtime cksum)' \
        '(-n --dry-run)'{-n,--dry-run}'[print what would transfer; move no bytes]' \
        '--exclude=[skip files matching fnmatch pattern (repeatable)]:glob' \
        '--include=[only transfer files matching pattern (repeatable)]:glob' \
        '--delete[with -r --sync: delete stale destination entries]' \
        '--remove-source[delete each source after successful transfer]' \
        '--verify[verify checksum against server after each transfer (root:// only)]' \
        '--tls[require in-protocol TLS (implied by roots://)]' \
        '--notlsok[permit cleartext if server offers no TLS]' \
        '--noverifyhost[skip TLS hostname verification (chain check stays on)]' \
        '--auth=[force authentication protocol]:proto:(gsi ztn krb5 sss unix)' \
        '--proxy=[X.509 proxy certificate path, overrides X509_USER_PROXY]:file:_files' \
        '--pgrw[use paged I/O (kXR_pgread/kXR_pgwrite) with per-page CRC32c]' \
        '--io-uring=[local-disk io_uring overlap ring mode]:mode:(on off auto)' \
        '--cksum=[verify checksum type after transfer]:type:(adler32 crc32c md5)' \
        '--compress=[enable inline compression on root:// transfers]:codec:(gzip deflate zstd br xz bzip2)' \
        '--zip[store local source in a STORE ZIP archive member]' \
        '--zip-append[like --zip but append to an existing archive]' \
        '(-S --streams)'{-S+,--streams=}'[open N-1 secondary kXR_bind data streams]:n' \
        '--tpc=[server-side third-party copy mode]:mode:(first only delegate)' \
        '--tpc-token-mode=[bearer-token forwarding mode for --tpc]:mode' \
        '(-T --token)'{-T+,--token=}'[WebDAV/HTTP bearer token (or $BEARER_TOKEN)]:jwt' \
        '--s3-access=[S3 SigV4 access key ID (or $AWS_ACCESS_KEY_ID)]:key' \
        '--s3-secret=[S3 SigV4 secret key (or $AWS_SECRET_ACCESS_KEY)]:key' \
        '--s3-region=[S3 SigV4 region (or $AWS_DEFAULT_REGION)]:region' \
        '--wire-trace=[decode every frame to stderr; N>=2 adds hex dump]:verbosity' \
        '--timing[print per-opcode round-trip time at end]' \
        '(-V --version)'{-V,--version}'[print version and exit]' \
        '(-h --help)'{-h,--help}'[print help and exit]' \
        '*: :_files'
}

# ---------------------------------------------------------------------------
# xrdfs
# ---------------------------------------------------------------------------
_brix_xrdfs() {
    local -a _fs_cmds
    _fs_cmds=(
        'stat:print file or directory metadata'
        'ls:list a directory'
        'du:recursive disk-usage summary'
        'df:disk space and quota report'
        'tree:ASCII directory tree'
        'find:recursive predicate search'
        'mkdir:create a directory'
        'rm:remove a file or directory tree'
        'rmdir:remove an empty directory'
        'mv:rename or move a file'
        'chmod:change permissions'
        'touch:update timestamps'
        'ln:create a link'
        'readlink:print symlink target'
        'truncate:truncate a file'
        'cat:print file contents'
        'head:print start of file'
        'tail:print end of file'
        'wc:count bytes/lines/words'
        'grep:search file for pattern'
        'hexdump:hex dump a file'
        'dd:copy with rate limiting'
        'upload:upload a local file'
        'download:download to a local file'
        'cmp:compare two remote files'
        'cksum:compute server-side checksum'
        'xattr:manage extended attributes'
        'readv:scatter-gather read'
        'writev:scatter-gather write'
        'locate:resolve replica locations'
        'query:send kXR_query request'
        'statvfs:filesystem statistics'
        'prepare:send kXR_prepare request'
        'stage:stage from tape'
        'evict:evict from cache'
        'explain:print session facts'
    )

    local -a _global_opts
    _global_opts=(
        '--tls[require in-protocol TLS]'
        '--notlsok[permit cleartext]'
        '--noverifyhost[skip TLS hostname verification]'
        '--auth=[authentication protocol]:proto:(gsi ztn krb5 sss unix)'
        '(-T --token)'{-T+,--token=}'[bearer token (or $BEARER_TOKEN)]:token'
        '--version[print version and exit]'
        '--help[print help and exit]'
    )

    if (( CURRENT == 2 )); then
        _arguments "${_global_opts[@]}" ': :' && return
        return
    fi

    if (( CURRENT == 3 )); then
        _describe 'command' _fs_cmds
        return
    fi

    case ${words[3]} in
    (ls|du|df)
        _arguments \
            '(-h --human)'{-h,--human}'[human-readable sizes]' \
            '(-j)'-j'[JSON output]' \
            "${_global_opts[@]}" ;;
    (tree)
        _arguments \
            '(-d --dirs-only)'{-d,--dirs-only}'[directories only]' \
            '(-L --depth)'{-L+,--depth=}'[maximum depth]:n' \
            "${_global_opts[@]}" ;;
    (rm)
        _arguments \
            '-r[recursive]' \
            '(-v --verbose)'{-v,--verbose}'[print each removed entry]' \
            "${_global_opts[@]}" ;;
    (touch)
        _arguments \
            '-c[do not create if absent]' \
            '-a[set access time only]' \
            '-m[set modification time only]' \
            '(-t --timestamp)'{-t+,--timestamp=}'[explicit time stamp]:stamp' \
            "${_global_opts[@]}" ;;
    (upload|download)
        _arguments \
            '--io-uring=[local I/O backend]:mode:(on off auto)' \
            '-f[overwrite existing destination]' \
            "${_global_opts[@]}" ;;
    (*)
        _arguments "${_global_opts[@]}" ;;
    esac
}


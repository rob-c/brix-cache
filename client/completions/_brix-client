# ---------------------------------------------------------------------------
# brixMount
# ---------------------------------------------------------------------------
_brix_brixMount() {
    local -a _mount_types
    _mount_types=(
        'cvmfs:mount read-only CVMFS repository'
        'cvmfs-rw:mount CVMFS repository with local writable overlay'
        'eos:mount EOS namespace via XRootDFS-brix (root://)'
        'root:mount XRootD namespace over root://'
        'roots:mount XRootD namespace over roots:// (TLS)'
    )

    if (( CURRENT == 2 )); then
        _arguments \
            '--overlay-list=[list overlay changes for mountdir]:mountdir:_files -/' \
            '--overlay-reset=[discard overlay changes for mountdir]:mountdir:_files -/' \
            '(-h --help)'{-h,--help}'[print help and exit]' \
            '--version[print version and exit]' \
            ': :_describe type _mount_types'
        return
    fi

    if (( CURRENT == 3 )); then
        case ${words[2]} in
        (cvmfs|cvmfs-rw) _message 'repository name (e.g. atlas.cern.ch)' ;;
        (eos|root|roots)  _message 'endpoint (root://host[:port] or host[:port])' ;;
        esac
        return
    fi

    if (( CURRENT == 4 )); then
        _files -/
        return
    fi

    # remaining: FUSE options pass-through
    _arguments \
        '-f[run in foreground]' \
        '-d[debug mode (implies -f)]' \
        '-o+[FUSE option]:opt' \
        '--overlay-list=[list overlay changes]:mountdir:_files -/' \
        '--overlay-reset=[discard overlay changes]:mountdir:_files -/'
}

# ---------------------------------------------------------------------------
# xrdstorascan
# ---------------------------------------------------------------------------
_brix_xrdstorascan() {
    local -a _scan_modes
    _scan_modes=(
        'verify:end-to-end verify one file by checksum'
        'bench:throughput and latency sweep'
        'dump:dump recorded checksums-at-rest via admin API'
        'fill:back-fill missing checksums-at-rest via admin API'
        'compare:verify all checksums-at-rest across a subtree'
    )

    if (( CURRENT == 2 )); then
        _describe 'mode' _scan_modes
        return
    fi

    local -a _common_opts
    _common_opts=(
        '--algo=[checksum algorithm]:algo:(adler32 crc32c crc64 md5)'
        '--json[machine-readable JSON output]'
        '--summary[print one-line summary only]'
    )

    case ${words[2]} in
    (verify)
        _arguments \
            "${_common_opts[@]}" \
            '-q[quiet: suppress output on success]' \
            ': :' ;;
    (bench)
        _arguments \
            "${_common_opts[@]}" \
            '--op=[operation to benchmark]:op:(read)' \
            '--block=[block size(s), comma-separated, K/M/G suffix]:sz' \
            '--parallel=[parallelism level(s), comma-separated]:n' \
            '--duration=[sweep duration in seconds]:s' \
            '--count=[request count instead of duration]:n' \
            '--pattern=[I/O access pattern]:pat:(seq random)' \
            ': :' ;;
    (dump|fill|compare)
        _arguments \
            "${_common_opts[@]}" \
            '--path=[limit scan to path prefix]:path' \
            '--password=[dashboard admin password]:pw' \
            '--insecure[skip TLS certificate verification]' \
            ': :' ;;
    (*)
        _arguments "${_common_opts[@]}" ': :' ;;
    esac
}


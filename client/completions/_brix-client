# ---------------------------------------------------------------------------
# xrdcksum (dispatcher)
# ---------------------------------------------------------------------------
_brix_xrdcksum() {
    local -a _ck_cmds
    _ck_cmds=(
        'crc32c:compute CRC32c checksum'
        'crc64:compute CRC-64/XZ checksum'
        'adler32:compute Adler-32 checksum'
        'verify:verify file against its recorded checksum'
        'info:dump .cinfo or xmeta xattr as JSON'
        'tree:produce a checksum manifest of a directory tree'
        'check:verify all files listed in a manifest'
    )

    if (( CURRENT == 2 )); then
        _describe 'subcommand' _ck_cmds
        return
    fi

    local -a _algo_opt
    _algo_opt=('--algo=[checksum algorithm]:algo:(adler32 crc32c crc64 crc64nvme md5)')

    case ${words[2]} in
    (verify)
        _arguments \
            '--cache[read proxy-cache .cinfo digest]' \
            '--storage[read user.XrdCks.* xattr and .cks sidecar]' \
            '--auto[consult both cache and storage (default)]' \
            "${_algo_opt[@]}" \
            '-q[quiet: print only on mismatch or error]' \
            '*: :_files' ;;
    (tree|check)
        _arguments \
            "${_algo_opt[@]}" \
            '-o+[write manifest to file instead of stdout]:file:_files' \
            '*: :_files' ;;
    (crc32c|crc64|adler32|info)
        _arguments "${_algo_opt[@]}" '*: :_files' ;;
    (*)
        _arguments '*: :_files' ;;
    esac
}

# ---------------------------------------------------------------------------
# xrdcrc32c / xrdcrc64 / xrdadler32  (hash-only symlinks)
# ---------------------------------------------------------------------------
_brix_cksum_hash() {
    _arguments '*: :_files'
}

# ---------------------------------------------------------------------------
# xrdckverify  (verify symlink)

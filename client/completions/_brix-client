    fi

    # Subcommand-specific flags for CURRENT >= 3
    case ${words[2]} in
    (cp|sync)
        _arguments \
            '--from=[read source list from file]:manifest:_files' \
            '--sync[skip matching-size destinations]' \
            '*: :_files' ;;
